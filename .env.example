# 复制为 .env 并填入你的 API Key（.env 不要提交到仓库）

# ---------- 评估基准（LLM 判分 / 多轮总结用） ----------
# 当前时间由本机读取；地点优先用此变量，未设置时则用本机公网 IP 解析（如香港测试、港币 HKD 不因此扣分）
# RAFT_EVAL_LOCATION=香港

# ---------- 推荐：SiliconFlow（DeepSeek-V3 / R1，大陆可用） ----------
# RAFT_LLM_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=你的_siliconflow_api_key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 推理型（Planner）：SILICONFLOW_PLANNER_MODEL=deepseek-ai/DeepSeek-R1
# 通用型（Evaluation/Query）：SILICONFLOW_GENERAL_MODEL=deepseek-ai/DeepSeek-V3

# ---------- 备用：Qwen（通义千问，大陆可用） ----------
# 使用 Qwen 时在 .env 中设置：
# RAFT_LLM_PROVIDER=qwen
# OPENAI_API_KEY=你的通义千问_api_key
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 可选：QWEN_MODEL 覆盖默认 deepseek-v3（亦可用 qwen-turbo、qwen-plus 等）
# QWEN_MODEL=deepseek-v3

# ---------- 正文提取（可选） ----------
# 设为 1 或 true 时，报告/判分中的「待测 Agent 输出」优先用 LLM 抽取正文，失败则回退规则。
# 与判分、出题共用同一套 OPENAI_API_KEY 与 RAFT_LLM_PROVIDER，无需重复配置；只需增加：
# RAFT_LLM_EXTRACT_BODY=1
# 可选：RAFT_LLM_EXTRACT_MODEL=qwen-turbo（不设则用上方 QWEN_MODEL 或默认）

# ---------- 可选：Grok（xAI） ----------
XAI_API_KEY=your_xai_api_key_here
# 可选：XAI_MODEL=grok-beta（若 404 请在 console.x.ai 查看可用模型）

# ---------- Poffices.ai RPA Bootstrap（scripts/run_poffices_bootstrap.py） ----------
# 登录 Poffices.ai 并选择 Agent 时使用，请勿提交到版本库
# POFFICES_USERNAME=你的用户名
# POFFICES_PASSWORD=你的密码
